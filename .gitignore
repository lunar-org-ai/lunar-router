# Python
__pycache__/
*.py[cod]
*$py.class
.Python
*.egg-info/
dist/
build/

# Virtual envs
.venv/
.python-version

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store

# Tests
.pytest_cache/
.coverage

# Logs
*.log

# uv
uv.lock

# Local env (API keys, secrets) — never commit
.env
.env.local

# Corpus index — operator-built locally; never committed
corpora/indexed/*.faiss
corpora/indexed/*.npy
corpora/indexed/manifest.jsonl
# Operator-curated documents may or may not be tracked; ignore by default
corpora/ingested/

# Multi-agent registry (P2.0) — each install builds its own catalog as
# the operator runs onboarding. Top-level only so backend/channels/agents
# and runtime/agents/ source dirs stay tracked.
/agents/

