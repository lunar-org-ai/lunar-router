# Lunar Router - Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# LLM Provider API Keys
# ===========================================
# Add the API keys for the providers you want to use

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
GOOGLE_API_KEY=...
MISTRAL_API_KEY=...
GROQ_API_KEY=gsk_...
COHERE_API_KEY=...
PERPLEXITY_API_KEY=pplx-...
CEREBRAS_API_KEY=...
SAMBANOVA_API_KEY=...

# ===========================================
# Lunar Configuration
# ===========================================

# Development mode (disables auth requirements)
LUNAR_DEV_MODE=true

# API Keys (format: key1:tenant1,key2:tenant2)
# Leave empty to use default dev key
LUNAR_API_KEYS=

# CORS Origins (comma-separated)
LUNAR_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ===========================================
# UniRoute (Semantic Routing) Configuration
# ===========================================

# Path to UniRoute state directory
UNIROUTE_STATE_PATH=./app/data/uniroute_state

# Embedding model for semantic routing
UNIROUTE_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Cost weight for routing decisions (0.0 = ignore cost, 1.0 = prioritize cost)
UNIROUTE_COST_WEIGHT=0.1

# ===========================================
# Server Configuration
# ===========================================

# Server host and port
HOST=0.0.0.0
PORT=8000

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
