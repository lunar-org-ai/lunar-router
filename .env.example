# OpenTracy — local environment.
#
# Copy this file to `.env`, fill in the values you need, then start the
# runtime / backend. The OSS distribution runs single-tenant on localhost,
# so most of these are optional — only ANTHROPIC_API_KEY is required.

# ─── Required ─────────────────────────────────────────────────────────────

# Your Anthropic API key. The harness and runtime route their model calls
# through this — no platform key, no fallback.
ANTHROPIC_API_KEY=

# ─── Optional ─────────────────────────────────────────────────────────────

# OpenAI key — only if you want to use OpenAI models alongside (or instead
# of) Anthropic in the agent pipeline.
# OPENAI_API_KEY=

# Backend API keys (comma-separated). When set, /v1/* routes require
# `Authorization: Bearer <one-of-these>`. Leave UNSET for OSS dev-mode
# (every request allowed) — fine for localhost, never for a public deploy.
# BACKEND_API_KEYS=

# Runtime URL — where the TS backend proxies /v1/* requests.
# Defaults to http://127.0.0.1:8001 if unset.
# RUNTIME_URL=http://127.0.0.1:8001

# Backend port. Default 8002.
# PORT=8002

# ─── Hosted / multi-tenant (default OFF) ─────────────────────────────────
# These are only relevant when running the multi-tenant variant from the
# private opentracy-infra repo. Leave OFF for OSS.

# OPENTRACY_MULTI_TENANT=0

# Google KMS key name for envelope-encrypting BYOK tenant secrets.
# Without this, secrets are stored plaintext at agent/secrets.env.
# OPENTRACY_KMS_KEY_NAME=

# E2B sandbox API key. Activates the autonomous engineering loop's
# remote execution path. Without this, the autonomous arm raises on
# first sandbox call — the rest of the harness still runs.
# OPENTRACY_E2B_API_KEY=
